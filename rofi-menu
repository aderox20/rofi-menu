#!/bin/bash

# Detect session
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  TERMINAL="foot"
  LOCK="swaylock"
  LOGOUT="swaymsg exit"
else
  TERMINAL="alacritty"
  LOCK="xflock4"
  LOGOUT="xfce4-session-logout"
fi

# Main menu
choice=$(printf "’äĀ  Terminal
’ü╝  Files
¾░Ć╗  Applications
’éģ  Fastfetch
’Ćō  System
’Ć©  Audio
’ć½  Network
’éŗ  Power" | rofi -dmenu -i -p "Menu")

case "$choice" in
"’äĀ  Terminal")
  $TERMINAL
  ;;

"’ü╝  Files")
  nautilus
  ;;

"¾░Ć╗  Applications")
  rofi -show drun -show-icons
  ;;

"’éģ  Fastfetch")
  # Fastfetch submenu with corrected Nerd Font icons
  ff_choice=$(printf "¾░Żć  Arch Linux
’ī£  Ubuntu
’īå  Debian
’īŖ  Fedora
’īÆ  Manjaro
’ī¬  Pop!_OS
’īö  openSUSE
’īŹ  Gentoo
’üä  Custom ASCII File" | rofi -dmenu -i -p "Fastfetch")

  case "$ff_choice" in
  "Ņ£Æ  Arch Linux" | "")
    $TERMINAL -e sh -c "fastfetch -l arch; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’ī£  Ubuntu")
    $TERMINAL -e sh -c "fastfetch -l ubuntu; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’īå  Debian")
    $TERMINAL -e sh -c "fastfetch -l debian; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’īŖ  Fedora")
    $TERMINAL -e sh -c "fastfetch -l fedora; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’īÆ  Manjaro")
    $TERMINAL -e sh -c "fastfetch -l manjaro; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’ī¬  Pop!_OS")
    $TERMINAL -e sh -c "fastfetch -l pop; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’īö  openSUSE")
    $TERMINAL -e sh -c "fastfetch -l opensuse; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’īŹ  Gentoo")
    $TERMINAL -e sh -c "fastfetch -l gentoo; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "’üä  Custom ASCII File")
    ascii_file=$(rofi -dmenu -i -p "ASCII file path (add your custom path to ts)")
    [ -f "$ascii_file" ] && $TERMINAL -e sh -c "fastfetch -i $ascii_file; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  esac
  ;;

"’Ćō  System")
  sub=$(printf "’Ŗö  Bluetooth
’Ćō  Settings
’ŗø  System Monitor" | rofi -dmenu -i -p "System")
  case "$sub" in
  "’Ŗö  Bluetooth") blueman-manager ;;
  "’Ćō  Settings") xfce4-settings-manager ;;
  "’ŗø  System Monitor") xfce4-taskmanager ;;
  esac
  ;;

"’Ć©  Audio")
  sub=$(printf "’Ć©  Volume Control
’ä░  Microphone" | rofi -dmenu -i -p "Audio")
  case "$sub" in
  "’Ć©  Volume Control") pavucontrol ;;
  "’ä░  Microphone") pavucontrol ;;
  esac
  ;;

"’ć½  Network")
  nm-connection-editor
  ;;

"’éŗ  Power")
  sub=$(printf "’ĆŻ  Lock
’éŗ  Logout
’Ć×  Reboot
’Ćæ  Shutdown" | rofi -dmenu -i -p "Power")
  case "$sub" in
  "’ĆŻ  Lock") $LOCK ;;
  "’éŗ  Logout") $LOGOUT ;;
  "’Ć×  Reboot") systemctl reboot ;;
  "’Ćæ  Shutdown") systemctl poweroff ;;
  esac
  ;;
esac
