#!/bin/bash

# Detect session
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  TERMINAL="foot"
  LOCK="swaylock"
  LOGOUT="swaymsg exit"
else
  TERMINAL="alacritty"
  LOCK="xflock4"
  LOGOUT="xfce4-session-logout"
fi

# Main menu
choice=$(printf "´äá  Terminal
´ü╝  Files
¾░Ç╗  Applications
´éà  Fastfetch
´Çô  System
´Ç¿  Audio
´ç½  Network
´éï  Power" | rofi -dmenu -i -p "Menu")

case "$choice" in
"´äá  Terminal")
  $TERMINAL
  ;;

"´ü╝  Files")
  nautilus
  ;;

"¾░Ç╗  Applications")
  rofi -show drun -show-icons
  ;;

"´éà  Fastfetch")
  # Fastfetch submenu with Default first
  ff_choice=$(printf "´à╝  Default
¾░úç  Arch Linux
´î£  Ubuntu
´îå  Debian
´îè  Fedora
´îÆ  Manjaro
´î¬  Pop!_OS
´îö  openSUSE
´îì  Gentoo
´îÅ  Linux Mint
´üä  Custom ASCII File" | rofi -dmenu -i -p "Fastfetch")

  case "$ff_choice" in
  "´à╝  Default")
    $TERMINAL -e sh -c "fastfetch; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "¾░úç  Arch Linux" | "")
    $TERMINAL -e sh -c "fastfetch -l arch; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´î£  Ubuntu")
    $TERMINAL -e sh -c "fastfetch -l ubuntu; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îå  Debian")
    $TERMINAL -e sh -c "fastfetch -l debian; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îè  Fedora")
    $TERMINAL -e sh -c "fastfetch -l fedora; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îÆ  Manjaro")
    $TERMINAL -e sh -c "fastfetch -l manjaro; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´î¬  Pop!_OS")
    $TERMINAL -e sh -c "fastfetch -l pop; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îö  openSUSE")
    $TERMINAL -e sh -c "fastfetch -l opensuse; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îì  Gentoo")
    $TERMINAL -e sh -c "fastfetch -l gentoo; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´îÅ  Linux Mint")
    $TERMINAL -e sh -c "fastfetch -l linuxmint; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  "´üä  Custom ASCII File")
    ascii_file=$(rofi -dmenu -i -p "ASCII file path (add your custom path to ts)")
    [ -f "$ascii_file" ] && $TERMINAL -e sh -c "fastfetch -i $ascii_file; read -n 1 -s -r -p 'Press any key to exit...'"
    ;;
  esac
  ;;

"´Çô  System")
  sub=$(printf "´èö  Bluetooth
´Çô  Settings
´ïø  System Monitor" | rofi -dmenu -i -p "System")
  case "$sub" in
  "´èö  Bluetooth") blueman-manager ;;
  "´Çô  Settings") xfce4-settings-manager ;;
  "´ïø  System Monitor") xfce4-taskmanager ;;
  esac
  ;;

"´Ç¿  Audio")
  sub=$(printf "´Ç¿  Volume Control
´ä░  Microphone" | rofi -dmenu -i -p "Audio")
  case "$sub" in
  "´Ç¿  Volume Control") pavucontrol ;;
  "´ä░  Microphone") pavucontrol ;;
  esac
  ;;

"´ç½  Network")
  nm-connection-editor
  ;;

"´éï  Power")
  sub=$(printf "´Çú  Lock
´éï  Logout
´Ç×  Reboot
´Çæ  Shutdown" | rofi -dmenu -i -p "Power")
  case "$sub" in
  "´Çú  Lock") $LOCK ;;
  "´éï  Logout") $LOGOUT ;;
  "´Ç×  Reboot") systemctl reboot ;;
  "´Çæ  Shutdown") systemctl poweroff ;;
  esac
  ;;
esac
