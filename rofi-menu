#!/bin/bash

# Detect session
if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
  TERMINAL="foot"
  LOCK="swaylock"
  LOGOUT="swaymsg exit"
else
  TERMINAL="alacritty"
  LOCK="xflock4"
  LOGOUT="xfce4-session-logout"
fi

# Main menu
choice=$(printf "’äĀ  Terminal
’ü╝  Files
¾░Ć╗  Applications
’éģ  Fastfetch
’Ćō  System
’Ć©  Audio
’ć½  Network
’éŗ  Power" | rofi -dmenu -i -p "Menu")

case "$choice" in
"’äĀ  Terminal")
  $TERMINAL
  ;;

"’ü╝  Files")
  nautilus
  ;;

"¾░Ć╗  Applications")
  rofi -show drun -show-icons
  ;;

"’éģ  Fastfetch")
  if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
    foot -e sh -c "fastfetch; read -n 1 -s -r -p 'Press any key to exit...'"
  else
    alacritty -e sh -c "fastfetch; read -n 1 -s -r -p 'Press any key to exit...'"
  fi
  ;;

"’Ćō  System")
  sub=$(printf "’Ŗö  Bluetooth
’Ćō  Settings
’ŗø  System Monitor" | rofi -dmenu -i -p "System")
  case "$sub" in
  "’Ŗö  Bluetooth") blueman-manager ;;
  "’Ćō  Settings") xfce4-settings-manager ;;
  "’ŗø  System Monitor") xfce4-taskmanager ;;
  esac
  ;;

"’Ć©  Audio")
  sub=$(printf "’Ć©  Volume Control
’ä░  Microphone" | rofi -dmenu -i -p "Audio")
  case "$sub" in
  "’Ć©  Volume Control") pavucontrol ;;
  "’ä░  Microphone") pavucontrol ;;
  esac
  ;;

"’ć½  Network")
  nm-connection-editor
  ;;

"’éŗ  Power")
  sub=$(printf "’ĆŻ  Lock
’éŗ  Logout
’Ć×  Reboot
’Ćæ  Shutdown" | rofi -dmenu -i -p "Power")
  case "$sub" in
  "’ĆŻ  Lock") $LOCK ;;
  "’éŗ  Logout") $LOGOUT ;;
  "’Ć×  Reboot") systemctl reboot ;;
  "’Ćæ  Shutdown") systemctl poweroff ;;
  esac
  ;;
esac
